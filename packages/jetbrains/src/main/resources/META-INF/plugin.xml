<idea-plugin package="com.wirespec.ide">
  <id>dev.wirespec.ide</id>
  <name>WireSpec IDE Companion</name>
  <vendor email="hello@wirespec.dev">WireSpec</vendor>
  <description><![CDATA[
    Thin IntelliJ Platform companion for WireSpec review tasks.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <resource-bundle>messages.WireSpecBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <postStartupActivity implementation="com.wirespec.ide.WireSpecStartupActivity"/>
    <statusBarWidgetFactory
      id="WireSpecStatusBar"
      implementation="com.wirespec.ide.WireSpecStatusBarWidgetFactory"/>
  </extensions>

  <actions>
    <action
      id="dev.wirespec.ide.OpenLatestTask"
      class="com.wirespec.ide.OpenLatestTaskAction"
      text="WireSpec: Open Latest Task File"
      description="Open the latest WireSpec task file">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>

    <action
      id="dev.wirespec.ide.OpenNextTask"
      class="com.wirespec.ide.OpenNextTaskAction"
      text="WireSpec: Open Next Open Task"
      description="Open the next open WireSpec task target">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>

    <action
      id="dev.wirespec.ide.ResolveTouchedThreads"
      class="com.wirespec.ide.ResolveTouchedThreadsAction"
      text="WireSpec: Resolve Touched Threads for Current File"
      description="Resolve touched WireSpec review threads for the current file">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>

    <action
      id="dev.wirespec.ide.ShowSummary"
      class="com.wirespec.ide.ShowSummaryAction"
      text="WireSpec: Show Review Summary"
      description="Show the current WireSpec review summary">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
